# .env.example — Movie QA Service
#
# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit the real .env file.
#
# Required variables are marked with (REQUIRED).
# Variables with defaults are marked with (default: value).
#
# LEARNING: We use a .env.example pattern rather than committing defaults
# directly to application config files. This makes it explicit what secrets
# the project needs without ever leaking real values into git history.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=movieqa
POSTGRES_PASSWORD=change_me_in_dev   # (REQUIRED) used by docker-compose

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_in_dev      # (REQUIRED)

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=movieqa
RABBITMQ_PASSWORD=change_me_in_dev   # (REQUIRED)

# ── External APIs ─────────────────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here         # (REQUIRED for Phase 1+) https://www.themoviedb.org/settings/api
ANTHROPIC_API_KEY=your_anthropic_key_here   # (REQUIRED for Phase 1+) https://console.anthropic.com
# OPENAI_API_KEY=your_openai_key_here       # Alternative to Anthropic — uncomment if preferred

# ── Auth service ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars  # (REQUIRED for Phase 5+)
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# ── Scheduler service ─────────────────────────────────────────────────────────
ADMIN_API_TOKEN=change_me_in_dev    # (REQUIRED for Phase 7+) used to trigger manual ingestion runs

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=                   # Only needed when connecting to Qdrant Cloud

# ── Spring services (shared) ──────────────────────────────────────────────────
# These are read by Spring Boot via application.yml ${...} placeholders.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/movieqa
SPRING_DATASOURCE_USERNAME=movieqa
SPRING_DATASOURCE_PASSWORD=change_me_in_dev
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=change_me_in_dev
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=movieqa
SPRING_RABBITMQ_PASSWORD=change_me_in_dev
